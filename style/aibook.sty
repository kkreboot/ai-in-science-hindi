  before skip=10pt, after skip=10pt,
  overlay={\node[anchor=north east, font=\cvHL\scriptsize, text=white,
     fill=cvBlue, rounded corners=3pt, inner xsep=5pt, inner ysep=1.5pt]
     at ([xshift=-5pt,yshift=3pt]frame.north east){Python};}
}

