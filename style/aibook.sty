% स्वयं जाँचें (self-check quiz QR; #1 = quiz URL)
\newcommand{\selfcheckqr}[1]{%
  \begin{tcolorbox}[aiboxbase, colback=cvPurple!6, colframe=cvPurple,
     title={\boxmk स्वयं जाँचें (Self-check Quiz)}]%
   \begin{minipage}[c]{0.74\linewidth}
     इस अध्याय की स्वतः-जाँच (auto-graded) प्रश्नोत्तरी हल करने हेतु QR स्कैन
     करें या लिंक खोलें:\\[2pt]{\footnotesize\nolinkurl{#1}}
   \end{minipage}\hfill
   \begin{minipage}[c]{0.22\linewidth}\raggedleft\qrcode[height=1.7cm]{#1}\end{minipage}%
  \end{tcolorbox}}

% Colab notebook link near a code listing (#1 = open-in-colab URL, encoded in QR)
\newcommand{\colabnb}[1]{%
  \par\nobreak\vspace{-2pt}\noindent\hfill
  {\footnotesize\sffamily\color{cvBlue}\shortstack[r]{%
     \textbf{इस कोड की Colab notebook}\\[-1pt]
     {\scriptsize\color{aigrey}चलाने हेतु QR स्कैन करें}}}%
  \hspace{6pt}\raisebox{-0.82cm}{\qrcode[height=1.15cm]{#1}}\par\vspace{3pt}}
