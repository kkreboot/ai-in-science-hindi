% ---------- अध्याय आरम्भ: dark-neon banner + विषय-चित्र (chapter opener) ----------
% संख्यांकित बनाम तारांकित (\chapter vs \chapter*) हेतु ध्वज
\makeatletter
\newif\ifnumchap
\let\ai@chapter\@chapter  \def\@chapter{\numchaptrue\ai@chapter}
\let\ai@schapter\@schapter \def\@schapter{\numchapfalse\ai@schapter}
\makeatother

\newcommand{\chapbannerbg}{%
  \begin{tikzpicture}[remember picture,overlay]
    \fill[cvBgDark] (current page.north west) rectangle ([yshift=-3.5cm]current page.north east);
    \draw[step=0.8cm,cvGridColor,line width=0.4pt,opacity=0.55]
      (current page.north west) grid ([yshift=-3.5cm]current page.north east);
    \fill[cvNeonCyan] ([yshift=-3.46cm]current page.north west)
      rectangle ([yshift=-3.56cm]current page.north east);
    \ifnumchap
      \node[anchor=west, text=cvNeonCyan, font=\cvHH\fontsize{15}{18}\selectfont]
        at ([xshift=2.4cm,yshift=-1.75cm]current page.north west) {अध्याय~\thechapter};
    \fi
  \end{tikzpicture}\par\nobreak
}
\newcommand{\chapbannericon}{%
  \ifnumchap
  \begin{tikzpicture}[remember picture,overlay]
    \ifcase\value{chapter}\or
      \pic[scale=1.35] at ([xshift=-3cm,yshift=-1.75cm]current page.north east){robot};\or
      \pic[scale=1.45] at ([xshift=-3cm,yshift=-1.75cm]current page.north east){atom};\or
      \pic[scale=1.45] at ([xshift=-3cm,yshift=-1.75cm]current page.north east){flask};\or
      \pic[scale=1.2] at ([xshift=-3cm,yshift=-1.6cm]current page.north east){dna};\or
      \pic[scale=1.2] at ([xshift=-3cm,yshift=-1.75cm]current page.north east){chip};\or
      \pic[scale=1.35] at ([xshift=-3cm,yshift=-1.75cm]current page.north east){bulb};\fi
  \end{tikzpicture}\par\nobreak
  \fi
}
\titleformat{\chapter}[display]
  {\thispagestyle{empty}\chapbannerbg\chapbannericon}
  {}{0pt}
  {\cvTH\fontsize{26}{31}\selectfont\color{cvBlue}}
  [\vspace{4pt}\textcolor{cvCyan}{\rule{4.6cm}{2.4pt}}]
\titlespacing*{\chapter}{0pt}{2.55cm}{24pt}

